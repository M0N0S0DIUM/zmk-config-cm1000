#include <dt-bindings/pinctrl/nrf-pinctrl.h>

&pinctrl {
    uart0_default: uart0_default {
        group1 {
            psels = <NRF_PSEL(UART_RX, 0, 8)>;
            bias-pull-up;
        };
        group2 {
            psels = <NRF_PSEL(UART_TX, 0, 6)>;
        };
    };

    uart0_sleep: uart0_sleep {
        group1 {
            psels = <NRF_PSEL(UART_RX, 0, 8)>,
                    <NRF_PSEL(UART_TX, 0, 6)>;
            low-power-enable;
        };
    };

    rgb_led_default: rgb_led_default {
        group1 {
            psels = <NRF_PSEL(GPIO, 1, 14)>;
        };
    };

    spi1_display_default: spi1_display_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 1, 11)>,
                    <NRF_PSEL(SPIM_MOSI, 1, 12)>;
        };
    };

    spi1_display_sleep: spi1_display_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 1, 11)>,
                    <NRF_PSEL(SPIM_MOSI, 1, 12)>;
            low-power-enable;
        };
    };

    encoder_a: encoder_a {
        group1 {
            psels = <NRF_PSEL(GPIO, 0, 2)>;
            bias-pull-up;
        };
    };

    encoder_b: encoder_b {
        group1 {
            psels = <NRF_PSEL(GPIO, 0, 3)>;
            bias-pull-up;
        };
    };

    encoder_sleep_a: encoder_sleep_a {
        group1 {
            psels = <NRF_PSEL(GPIO, 0, 2)>;
            low-power-enable;
        };
    };

    encoder_sleep_b: encoder_sleep_b {
        group1 {
            psels = <NRF_PSEL(GPIO, 0, 3)>;
            low-power-enable;
        };
    };
};

&spi1_display {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi1_display_default>;
    pinctrl-1 = <&spi1_display_sleep>;
    pinctrl-names = "default", "sleep";

    cs-gpios = <&gpio1 13 GPIO_ACTIVE_HIGH>;

    nice_view: ls011b7dh03@0 {
        compatible = "sharp,ls011b7dh03";
        reg = <0>;
        spi-max-frequency = <2000000>;
        width = <160>;
        height = <68>;
    };
};
