/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/led/led.h>

#include "cm1000-pinctrl.dtsi"
#include "cm1000-layouts.dtsi"

/ {
    model = "cm1000";
    compatible = "cm1000";

    chosen {
        zephyr,code-partition = &code_partition;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zmk,physical-layout = &default_layout;
        zmk,underglow = &rgb_led_strip;
        zmk,display = &nice_view;
        zmk,battery = &fuel_gauge;
    };

    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&matrix_transform0>;
        kscan = <&kscan0>;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        col-gpios
            = <&gpio0 8 GPIO_ACTIVE_HIGH>,
              <&gpio0 14 GPIO_ACTIVE_HIGH>,
              <&gpio0 16 GPIO_ACTIVE_HIGH>,
              <&gpio0 17 GPIO_ACTIVE_HIGH>,
              <&gpio0 20 GPIO_ACTIVE_HIGH>,
              <&gpio0 21 GPIO_ACTIVE_HIGH>,
              <&gpio0 22 GPIO_ACTIVE_HIGH>,
              <&gpio0 24 GPIO_ACTIVE_HIGH>,
              <&gpio0 25 GPIO_ACTIVE_HIGH>,
              <&gpio0 27 GPIO_ACTIVE_HIGH>,
              <&gpio0 28 GPIO_ACTIVE_HIGH>,
              <&gpio0 29 GPIO_ACTIVE_HIGH>,
              <&gpio0 30 GPIO_ACTIVE_HIGH>,
              <&gpio0 31 GPIO_ACTIVE_HIGH>,
              <&gpio1 1 GPIO_ACTIVE_HIGH>,
              <&gpio1 2 GPIO_ACTIVE_HIGH>,
              <&gpio1 3 GPIO_ACTIVE_HIGH>;

        row-gpios
            = <&gpio1 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
              <&gpio1 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
    };

    matrix_transform0: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <17>;
        rows = <6>;

        map = <
            RC(0,0) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,11) RC(0,12) RC(0,13) RC(0,14)
            RC(0,15)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)   RC(1,14) RC(2,15) RC(2,14)

            RC(2,0) RC(2,1) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13)

            RC(3,0) RC(3,1) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13)
            RC(3,16)

            RC(4,0) RC(4,2) RC(4,3) RC(4,4) RC(4,5) RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10) RC(4,11) RC(4,13) RC(4,15)
            RC(4,16)

            RC(5,0) RC(5,1) RC(5,2)
            RC(5,6)
            RC(5,10) RC(5,12) RC(5,13) RC(5,14)           RC(5,15) RC(5,16)
        >;
    };

    leds {
        compatible = "gpio-leds";
        blue_led: led_0 {
            gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
        };
    };

    /* Rotary Encoder - configured with GPIO properties (not pinctrl) */
    encoder: ec11 {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;  /* ROTA on P0.2 (AIN0) */
        b-gpios = <&gpio0 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;  /* ROTB on P0.3 (AIN1) */
        steps = <80>;  /* Pulses per rotation for EC11 encoder */
        status = "okay";  /* Enable the encoder */
    };
    /* Sensors node for encoders */
    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder>;  /* Reference the encoder we defined above */
        triggers-per-rotation = <20>;  /* Number of sensor events per full rotation */
    };

};

&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi3_rgb_default>;
    pinctrl-1 = <&spi3_rgb_sleep>;
    pinctrl-names = "default", "sleep";

    /* RGB LED strip data is on MOSI P1.14. */
    rgb_led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;
        chain-length = <82>;
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
    };
};

&spi1 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi1_display_default>;
    pinctrl-1 = <&spi1_display_sleep>;
    pinctrl-names = "default", "sleep";

    cs-gpios = <&gpio1 13 GPIO_ACTIVE_HIGH>;

    nice_view: ls011b7dh03@0 {
        compatible = "sharp,ls011b7dh03";
        reg = <0>;
        spi-max-frequency = <2000000>;
        width = <160>;
        height = <68>;
    };
};

&i2c1 {
    compatible = "nordic,nrf-twi";
    status = "okay";
    pinctrl-0 = <&i2c1_battery_default>;
    pinctrl-1 = <&i2c1_battery_sleep>;
    pinctrl-names = "default", "sleep";

    fuel_gauge: max17048@36 {
        compatible = "zmk,maxim-max17048";
        status = "okay";
        reg = <0x36>;
    };
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        code_partition: partition@1000 {
            reg = <0x00001000 DT_SIZE_K(844)>;
        };

        storage_partition: partition@d4000 {
            reg = <0x000d4000 DT_SIZE_K(128)>;
        };

        boot_partition: partition@f4000 {
            reg = <0x000f4000 DT_SIZE_K(48)>;
        };
    };
};

&adc { status = "okay"; };
&gpiote { status = "okay"; };
&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };

zephyr_udc0: &usbd { status = "okay"; };
